# ── Dependencies ──────────────────────────────────────────────
node_modules/

# ── Environment Variables (NEVER commit these) ─────────────────
.env
.env.local
.env.development
.env.production
.env.staging
.env.test

# ── Security: token files written to disk ─────────────────────
*.txt
reset-token.txt
verify-token.txt
email-preview.html

# ── Uploads (user content, not code) ──────────────────────────
uploads/
!uploads/.gitkeep

# ── Build outputs ─────────────────────────────────────────────
dist/
build/

# ── OS / Editor artifacts ─────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Test / Temp files ─────────────────────────────────────────
test-*.js
check-*.js
